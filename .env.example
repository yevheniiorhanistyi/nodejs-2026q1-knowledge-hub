PORT=4000

CRYPT_SALT=10

JWT_SECRET=super_secret_key
JWT_REFRESH_SECRET=another_super_secret_key
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=knowledge_hub
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL="postgresql://postgres:root@localhost:5432/knowledge_hub?schema=public"

LOG_LEVEL=log
LOG_MAX_FILE_SIZE=1024

GEMINI_API_KEY=your_gemeni_api_key_here
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-2.5-flash
AI_RATE_LIMIT_RPM=20
AI_CACHE_TTL_SEC=300

GEMINI_EMBEDDING_MODEL=gemini-embedding-001
RAG_VECTOR_DB_PROVIDER=qdrant
RAG_VECTOR_DB_URL=http://vectordb:6333
RAG_VECTOR_COLLECTION=knowledge_hub_articles
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=200
RAG_CONVERSATION_MAX_MESSAGES=20